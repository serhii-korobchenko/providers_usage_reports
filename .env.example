# Core
COST_PROVIDERS=openai,railway,google_cloud

# Telegram
TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# OpenAI
OPENAI_ADMIN_KEY=sk-admin-...
OPENAI_COST_GROUP_BY=project_id,line_item

# Railway
RAILWAY_API_TOKEN=railway_token_here
RAILWAY_TEAM_ID=
RAILWAY_PROJECT_ID=

# Google Cloud / BigQuery billing export
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# or use a mounted file path instead of JSON
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-service-account.json
GCP_BILLING_PROJECT_ID=your-billing-project-id
GCP_BILLING_TABLE=your-project.your_dataset.gcp_billing_export_v1
